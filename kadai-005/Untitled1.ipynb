      "source": [
        "# 与えられた値\n",
        "top = 10      # 上辺(cm)\n",
        "bottom = 20   # 下辺(cm)\n",
        "height = 5    # 高さ(cm)\n",
        "\n",
        "# 面積の計算\n",
        "area = (top + bottom) * height / 2\n",
        "\n",
        "# 結果の出力（strで変換して連結）\n",
        "print(str(area) + \"cm²\")"
      ]
    }
