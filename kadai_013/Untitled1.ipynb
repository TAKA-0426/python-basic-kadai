      "source": [
        "# 消費税込み金額を計算する関数\n",
        "def calc_tax(price, tax_rate):\n",
        "    total = price * (1 + tax_rate / 100)\n",
        "    return total\n",
        "\n",
        "# 関数の呼び出し（第1引数：110円、第2引数：10%）\n",
        "result = calc_tax(110, 10)\n",
        "\n",
        "# 結果の表示\n",
        "print(result)"
      ],
