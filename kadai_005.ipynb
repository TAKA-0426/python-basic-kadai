      ],
      "source": [
        "#値を設定\n",
        "top=10      #上辺(cm)\n",
        "bottom=20   #下辺（㎝）\n",
        "heigt=5     #高さ(cm)\n",
        "\n",
        "#面積の計算\n",
        "area=(top+bottom)*heigt/2\n",
        "\n",
        "#結果の表示\n",
        "print(\"台形の面積は\",area,\"㎠です\")\n",
        "\n",
        "\n",
        "\n"
      ]
    }
